{
  "name": "agent",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["web"],
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --hot index.ts",
    "voice": "bun run voice/index.ts",
    "voice:dev": "bun --hot voice/index.ts",
    "web": "turbo dev --filter=web",
    "web:build": "turbo build --filter=web",
    "dev:all": "turbo dev",
    "typecheck": "tsc --noEmit",
    "install:all": "bun install"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@dynamic-labs-wallet/node-evm": "^0.0.293",
    "@langchain/anthropic": "^1.3.18",
    "@langchain/core": "^1.1.25",
    "@langchain/google-genai": "^2.1.19",
    "@langchain/langgraph": "^1.1.4",
    "@lifi/sdk": "^3.14.1",
    "@polymarket/clob-client": "^5.1.1",
    "elevenlabs": "^1.59.0",
    "ethers": "^5.8.0"
  }
}
