# ─── Dynamic ──────────────────────────────────────────────────────────────────
# Same environment ID as the parent .env DYNAMIC_ENVIRONMENT_ID
NEXT_PUBLIC_DYNAMIC_ENV_ID=your_dynamic_environment_id

# From Dynamic Dashboard → Developers → Webhooks → your webhook's secret
DYNAMIC_WEBHOOK_SECRET=your_dynamic_webhook_secret

# RSA private key for decrypting delegation payloads from the webhook.
# Generate: openssl genrsa -out private.pem 4096
# Then upload the public key in Dynamic Dashboard → Wallets → Delegation
DYNAMIC_DELEGATION_PRIVATE_KEY="your_rsa_private_key_pem_with_newlines_as_backslash_n"

# Same as parent .env DYNAMIC_API_KEY (dyn_...)
DYNAMIC_API_KEY=dyn_your_server_api_key

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
