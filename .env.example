# ─── Dynamic Dashboard credentials ───────────────────────────────────────────
# Get from https://app.dynamic.xyz/dashboard
DYNAMIC_API_KEY=dyn_your_server_api_key_here
DYNAMIC_ENVIRONMENT_ID=your_environment_id_here

# User session JWT — required for fetching token balances via Dynamic's SDK API.
# Obtain from an authenticated session (Authorization: Bearer <token> header).
DYNAMIC_USER_JWT=your_user_jwt_here

# ─── Anthropic API key ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Delegated Wallet (agent's wallet) ───────────────────────────────────────
# Set these from the webhook payload received when user approves delegation.
DELEGATED_WALLET_ID=your_wallet_id_here
DELEGATED_WALLET_ADDRESS=0x...

# ── Option A: Pre-decrypted credentials (recommended for development) ─────────
# DELEGATED_WALLET_API_KEY=<decrypted walletApiKey string>
# DELEGATED_KEY_SHARE=<decrypted keyShare as JSON string>

# ── Option B: Decrypt at startup (from webhook encrypted payload) ─────────────
# DELEGATION_KEY="<your RSA private key PEM, with newlines as \n>"
# ENCRYPTED_WALLET_API_KEY={"alg":"HYBRID-RSA-AES-256","ct":"...","ek":"...","iv":"...","tag":"..."}
# ENCRYPTED_KEY_SHARE={"alg":"HYBRID-RSA-AES-256","ct":"...","ek":"...","iv":"...","tag":"..."}

# ─── ElevenLabs (voice mode) ──────────────────────────────────────────────────
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice ID for TTS — find IDs at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=your_voice_id_here
